@model RecipeShare.Business.DTOs.RegisterDTO

@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6 d-none d-md-block">
                    <img src="~/images/recipe_share.jpg"
                         class="img-fluid h-100 w-100"
                         style="object-fit: cover; min-height: 600px;"
                         alt="Join Recipe Share">
                    </div>

                    <div class="col-md-6 bg-white">
                        <div class="card-body p-5">
                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-success">Aramıza Katıl</h2>
                                <p class="text-muted">Mutfak sırlarımızı paylaşmaya başlayalım.</p>
                            </div>

                            <form asp-action="Register" method="post">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>
                            
                                <div class="mb-3">
                                    <label asp-for="Username" class="form-label fw-semibold small">Kullanıcı Adı</label>
                                    <input asp-for="Username" class="form-control bg-light border-0 py-2" />
                                    <span asp-validation-for="Username" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold small">E-Posta</label>
                                    <input asp-for="Email" class="form-control bg-light border-0 py-2" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold small">Şifre</label>
                                    <input asp-for="Password" type="password" class="form-control bg-light border-0 py-2" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <button type="submit" class="btn btn-success w-100 py-2 rounded-pill fw-bold transition-hover shadow-sm">
                                    Kayıt Ol <i class="fas fa-user-plus ms-1"></i>
                                </button>
                            </form>
                        
                            <div class="text-center mt-3">
                                <p class="mb-0 text-muted small">Zaten bir hesabınız var mı? <a asp-action="Login" class="text-success fw-bold text-decoration-none">Giriş Yap</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(25, 135, 84, 0.3);
            transition: all 0.3s ease;
        }
    </style>