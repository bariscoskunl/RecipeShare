@model RecipeShare.Business.DTOs.LoginDTO

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6 d-none d-md-block">
                    <img src="~/images/recipe_share.jpg"
                         class="img-fluid h-100 w-100"
                         style="object-fit: cover; min-height: 500px;"
                         alt="Recipe Share">
                    </div>
                
                    <div class="col-md-6 bg-white d-flex align-items-center">
                        <div class="card-body p-5 w-100">
                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-success">Hoş Geldiniz</h2>
                                <p class="text-muted">Tariflerinizi paylaşmak için giriş yapın.</p>
                            </div>
                        
                            <form asp-action="Login" method="post">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>
                            
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold small">E-Posta</label>
                                    <input asp-for="Email" class="form-control bg-light border-0 py-2" placeholder="mail@example.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold small">Şifre</label>
                                    <input asp-for="Password" type="password" class="form-control bg-light border-0 py-2" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            
                                <button type="submit" class="btn btn-success w-100 py-2 rounded-pill fw-bold transition-hover shadow-sm">
                                    Giriş Yap <i class="fas fa-sign-in-alt ms-1"></i>
                                </button>
                            </form>
                        
                            <div class="text-center mt-4">
                                <p class="mb-0 text-muted small">Hesabınız yok mu? <a asp-action="Register" class="text-success fw-bold text-decoration-none">Hemen Kaydolun</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
            transition: all 0.3s ease;
        }
    </style>