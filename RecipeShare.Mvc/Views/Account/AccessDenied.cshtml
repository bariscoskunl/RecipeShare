@{
    ViewData["Title"] = "Erişim Engellendi";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5 text-center">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-danger py-4 shadow-sm">
                    <i class="fas fa-user-lock text-white" style="font-size: 4rem;"></i>
                </div>
                
                <div class="card-body p-5 bg-white">
                    <h2 class="fw-bold text-dark mb-3">Hoppala! Burası Yasak</h2>
                    <p class="text-muted mb-4">
                        Üzgünüz Barış, bu mutfak sırrını düzenleme yetkin bulunmuyor.
                        Sadece kendi tariflerinde şef sensin, başkalarınınkine sadece bakabilirsin!
                    </p>
                    
                    <div class="d-grid gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-success rounded-pill py-3 fw-bold transition-hover shadow-sm">
                            <i class="fas fa-home me-2"></i>Ana Sayfaya Dön
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill py-2 fw-semibold">
                            <i class="fas fa-arrow-left me-2"></i>Geri Git
                        </a>
                    </div>
                </div>
                
                <div class="card-footer bg-light border-0 py-3">
                    <small class="text-muted italic">Eğer bir hata olduğunu düşünüyorsan giriş bilgilerini kontrol et.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(25, 135, 84, 0.2) !important;
        transition: all 0.3s ease;
    }
</style>