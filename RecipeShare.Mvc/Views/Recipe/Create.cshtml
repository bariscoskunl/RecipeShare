@model RecipeShare.Business.DTOs.RecipeDTO

@{
    ViewData["Title"] = "Yeni Tarif Ekle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="text-center mb-4">
            <h2>
                <i class="fas fa-plus-circle me-2"></i>Yeni Tarif Paylaş
            </h2>
            <p class="text-muted">Mutfak sırlarını toplulukla paylaşmaya hazır mısın?</p>
        </div>
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-dark">Tarif Adı</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-utensils text-success"></i></span>
                            <input asp-for="Title" class="form-control border-0 bg-light py-3" placeholder="Örn: Anne Köftesi" />
                        </div>
                        <span asp-validation-for="Title" class="text-danger small ms-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-dark">Hazırlanışı ve Malzemeler</label>
                        <textarea asp-for="Content" class="form-control border-0 bg-light shadow-sm rounded-3 py-3"
                                  rows="10" placeholder="Malzemeleri ve yapım aşamalarını detaylıca yazın..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small ms-1"></span>
                    </div>
                   <div class="mb-5">
                    <label class="form-label fw-bold text-dark">Tarif Fotoğrafı Seç</label>
                     <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <span class="input-group-text bg-white border-0"><i class="fas fa-camera text-success"></i></span>
                        <input type="file" name="ImageFile" id="imageFile" class="form-control border-0 bg-light py-3" accept="image/*" />
                     </div>
                        <small class="text-muted ms-1 mt-1 d-block italic">Kendi hazırladığın lezzetin fotoğrafını yükle!</small>
                      </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 py-3 rounded-pill fw-bold transition-hover">
                                <i class="fas fa-times me-2"></i>Vazgeç
                            </a>
                        </div>
                        <div class="col-md-6">
                            <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow transition-hover">
                                <i class="fas fa-save me-2"></i>Tarifi Yayınla
                            </button>
                        </div>
                    </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

   <style>
    .transition-hover {
        transition: all 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    /* Form odaklandığında kenarlık rengini yumuşatma */
    .form-control:focus {
        background-color: #fff !important;      
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25) !important;
        border: 1px solid #198754 !important;
    }
</style>