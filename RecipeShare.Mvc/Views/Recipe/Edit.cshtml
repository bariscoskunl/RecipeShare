
@model RecipeShare.Business.DTOs.RecipeDTO

@{
    ViewData["Title"] = "Tarifi Düzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent p-0 m-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted small">Ana Sayfa</a></li>
                <li class="breadcrumb-item active text-success fw-bold small" aria-current="page">Tarifi Düzenle</li>
            </ol>
        </nav>

        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">
                <i class="fas fa-edit me-2"></i>Tarifi Güncelle
            </h2>
            <p class="text-muted">"@Model.Title" tarifinde ufak dokunuşlar yapalım.</p>
        </div>

        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-dark">Tarif Adı</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-utensils text-success"></i></span>
                            <input asp-for="Title" class="form-control border-0 bg-light py-3" />
                        </div>
                        <span asp-validation-for="Title" class="text-danger small ms-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-bold text-dark">Hazırlanışı ve Malzemeler</label>
                        <textarea asp-for="Content" class="form-control border-0 bg-light shadow-sm rounded-3 py-3" 
                                  rows="10"></textarea>
                        <span asp-validation-for="Content" class="text-danger small ms-1"></span>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-3 rounded-pill fw-bold transition-hover">
                                <i class="fas fa-arrow-left me-2"></i>Değişiklikleri İptal Et
                            </a>
                        </div>
                        <div class="col-md-6">
                            <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow transition-hover">
                                <i class="fas fa-check-circle me-2"></i>Güncelleştirmeleri Kaydet
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    /* Input Focus Efekti */
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15) !important;
        border: 1px solid #198754 !important;
    }
</style>